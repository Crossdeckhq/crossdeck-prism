{
  "name": "@cross-deck/ai",
  "mcpName": "com.cross-deck/prism",
  "version": "0.3.1",
  "description": "Prism \u2014 the AI/MCP layer over Crossdeck. Cross your revenue, errors, entitlements and identity in one question: which paying customer did this error hit, and what are they worth versus what they cost? The cross-layer answers no errors, billing, or analytics tool can give alone.",
  "type": "module",
  "bin": {
    "crossdeck-ai": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('ui','dist/ui',{recursive:true})\"",
    "start": "node dist/server.js",
    "test": "node --test dist/*.test.js",
    "dev": "tsc --watch",
    "prepublishOnly": "node scripts/guard-ci-publish.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "error-monitoring",
    "error-tracking",
    "observability",
    "revenue",
    "mrr",
    "subscriptions",
    "entitlements",
    "identity",
    "cross-platform",
    "attribution",
    "customer-success",
    "churn",
    "analytics",
    "firebase",
    "claude",
    "cursor",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.5.0"
  }
}
